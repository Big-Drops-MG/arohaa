{
  "name": "arohaa",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "kill:dev": "powershell -NoProfile -Command \"$ErrorActionPreference='SilentlyContinue'; Get-NetTCPConnection -LocalPort 3000,3001,3002 | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force }; exit 0\"",
    "predev": "pnpm kill:dev",
    "predev:web": "pnpm kill:dev",
    "dev": "turbo dev --continue",
    "dev:web": "turbo dev --continue --filter=dashboard --filter=@workspace/api",
    "dev:infra": "docker compose up -d redis clickhouse",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "db:migrate": "pnpm --filter @workspace/database db:migrate",
    "db:push": "pnpm --filter @workspace/database db:push",
    "prepare": "husky",
    "vercel:link": "pnpm dlx vercel@latest link --yes --cwd apps/dashboard --scope big-drops-mg-admins-projects --project arohaa-dashboard",
    "vercel:env:pull": "pnpm dlx vercel@latest env pull --cwd apps/dashboard"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.14.0",
    "dotenv": "^16.6.1",
    "tsx": "^4.21.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "apps/dashboard/**/*.{ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/ui/**/*.{ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/eslint-config/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
