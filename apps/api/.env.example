# Copy to repo root `.env` for local development.

# Ingest API (Fastify on port 3001)
AROHAA_INTERNAL_API_SECRET=dev-arohaa-internal-local
NEXT_PUBLIC_AROHAA_INGEST_API_BASE=http://127.0.0.1:3001
INGEST_BASE_URL=http://127.0.0.1:3001

# ClickHouse (start with: pnpm dev:infra)
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Redis (start with: pnpm dev:infra)
REDIS_URL=redis://127.0.0.1:6379
