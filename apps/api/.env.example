# Template only — copy real values to ECS task env / Secrets Manager (never commit secrets).
# Local dev: API auto-loads apps/dashboard/.env.local when apps/api/.env.local is missing.

NODE_ENV=production
PORT=3001

# Must match dashboard / Vercel AROHAA_INTERNAL_API_SECRET
AROHAA_INTERNAL_API_SECRET=your-shared-internal-secret

# Same Neon URL as dashboard DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-example-pooler.region.aws.neon.tech/neondb?sslmode=require

# Same Upstash URL as dashboard REDIS_URL or KV_URL
REDIS_URL=rediss://default:UPSTASH_TOKEN@your-instance.upstash.io:6379

# Same ClickHouse Cloud as dashboard
CLICKHOUSE_URL=https://YOUR-SERVICE.region.aws.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password

# CloudWatch logs (prefer ECS task IAM role over long-lived keys)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional
# SENTRY_DSN=
