{
  "name": "@workspace/sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/sdk.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/sdk.ts --bundle --minify --outfile=dist/sdk.js && cp dist/sdk.js dist/sdk.v1.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
