{
  "name": "arohaa",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "kill:dev": "node scripts/kill-dev-ports.mjs",
    "predev": "pnpm kill:dev",
    "predev:web": "pnpm kill:dev",
    "dev": "turbo dev --continue",
    "dev:web": "turbo dev --continue --filter=dashboard --filter=@workspace/api",
    "dev:infra": "docker compose up -d redis clickhouse",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter dashboard test:e2e",
    "test:load": "k6 run scripts/load/ingest.k6.js",
    "db:migrate": "pnpm --filter @workspace/database db:migrate",
    "db:push": "pnpm --filter @workspace/database db:push",
    "clickhouse:migrate": "tsx scripts/migrate-clickhouse-phase1.mts",
    "prepare": "husky",
    "vercel:link": "pnpm dlx vercel@latest link --yes --cwd apps/dashboard --scope big-drops-mg-admins-projects --project arohaa-dashboard",
    "vercel:env:pull": "pnpm dlx vercel@latest env pull --cwd apps/dashboard"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.14.0",
    "dotenv": "^16.6.1",
    "tsx": "^4.21.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "apps/dashboard/**/*.{ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/ui/**/*.{ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/eslint-config/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
